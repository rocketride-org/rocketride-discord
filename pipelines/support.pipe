    {
      "id": "qdrant_1",
      "provider": "qdrant",
      "name": "Qdrant",
      "config": {
        "profile": "local",
        "local": {
          "host": "localhost",
          "port": 6333,
          "score": 0.6,
          "collection": "ROCKETRIDE_DOCS"
        }
      },
      "input": [
        {
          "lane": "questions",
          "from": "embedding_transformer_1"
        }
